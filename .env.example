# ==============================================================================
# APEX Platform - Environment Variable Template
# ==============================================================================
# Instructions:
# Copy this file to '.env' and fill in the values below. DO NOT commit '.env' to version control.

# ------------------------------------------------------------------------------
# 1. Core Operating Environment
# ------------------------------------------------------------------------------
# Defines the environment (development, staging, production)
APEX_ENV=development

# ------------------------------------------------------------------------------
# 2. Microsoft Foundry Configuration (Agent 1)
# ------------------------------------------------------------------------------
# These keys are required to interface with the Foundry Control Plane for 
# PII scrubbing, compliance checks, and model routing.
FOUNDRY_ENDPOINT=https://api.foundry.microsoft.com/v1
FOUNDRY_API_KEY=your_foundry_api_key_here

# ------------------------------------------------------------------------------
# 3. Azure OpenAI / AutoGen Models (Agent 2 & Agent 4)
# ------------------------------------------------------------------------------
# Used by the Agent Framework Orchestrator and Cost Orchestrator for inference
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT_GPT4=gpt-4
AZURE_OPENAI_DEPLOYMENT_SONNET=claude-3-sonnet # If routed through Azure/Foundry

# Fallback standard OpenAI key if not using Azure exclusively
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------------------------
# 4. Azure Infrastructure & Memory (Agent 6)
# ------------------------------------------------------------------------------
# For local development without Managed Identities, you may need explicit endpoints/strings.
# In production Container Apps, these are retrieved dynamically.

# Cosmos DB for persistent Agent Memory
COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# If using Managed Identity locally via `az login`, the key is not needed.
COSMOS_DB_KEY=your_cosmos_db_master_key_here
COSMOS_DB_DATABASE_NAME=apex-memory-db
COSMOS_DB_CONTAINER_NAME=agents

# Application Insights for OpenTelemetry correlation
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=...

# ------------------------------------------------------------------------------
# 5. External Integrations (MCP Servers - Agent 3)
# ------------------------------------------------------------------------------
# Slack / PagerDuty webhooks for the Alert Server
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/workspace/details

# ------------------------------------------------------------------------------
# 6. React Frontend (Agent 8)
# ------------------------------------------------------------------------------
# Variables starting with REACT_APP_ are injected into the frontend build
REACT_APP_WEBSOCKET_URL=ws://localhost:8000/ws
REACT_APP_API_URL=http://localhost:8000/api
